-- Configuration for KOReader KOAssistant Plugin
-- Copy this file to configuration.lua and modify as needed
--
-- PRIORITY: Settings UI values always take precedence.
-- This file provides defaults for settings NOT configured via the UI.
--
-- MAIN USE CASE: Custom API endpoints (proxies, regional mirrors)
-- Most other settings are easier to manage through the Settings UI:
--   Tools > KOAssistant > Settings
--
-- All settings are optional - uncomment only what you need

local CONFIGURATION = {
    -- ============================================================
    -- PROVIDER & MODEL
    -- ============================================================
    -- These are used as defaults until changed in the Settings UI.
    -- Once you pick a provider/model in the UI, the UI value wins.
    --
    -- Built-in providers: anthropic, openai, deepseek, gemini, ollama,
    --   groq, mistral, xai, openrouter, qwen, kimi, together, fireworks,
    --   sambanova, cohere, doubao, zai, perplexity
    --
    -- provider = "anthropic",
    -- model = "claude-sonnet-4-6",

    -- ============================================================
    -- CUSTOM API ENDPOINTS (the main reason to use this file)
    -- ============================================================
    -- Override the default API URL for any built-in provider.
    -- Useful for proxies, regional mirrors, or self-hosted endpoints.
    --
    -- Only set base_url for providers you actually need to override.
    -- The model field here is optional — the UI model picker still works.
    --
    --[[
    provider_settings = {
        openai = {
            base_url = "https://your-proxy.example.com/v1/chat/completions",
        },
        anthropic = {
            base_url = "https://your-proxy.example.com/v1/messages",
        },
        gemini = {
            -- Gemini base_url is the prefix; the handler appends /{model}:generateContent
            base_url = "https://your-proxy.example.com/v1beta/models",
        },
        deepseek = {
            base_url = "https://your-proxy.example.com/v1/chat/completions",
        },
    },
    --]]

    -- ============================================================
    -- FEATURE OVERRIDES
    -- ============================================================
    -- These serve as defaults until changed in the Settings UI.
    -- Once a setting is changed via the UI, the UI value takes priority.
    --
    features = {
        -- Display
        -- hide_highlighted_text = false,      -- Hide highlighted text in responses
        -- hide_long_highlights = true,        -- Replace long highlights with "..."
        -- long_highlight_threshold = 280,     -- Characters before highlight is "long"

        -- Translation
        -- translation_language = "English",   -- Target language for Translate action

        -- Response rendering
        -- render_markdown = true,             -- Format responses (bold, lists, etc.)
        -- markdown_font_size = 20,            -- Font size for formatted text (14-30)

        -- Chat management
        -- auto_save_chats = true,             -- Auto-save when continuing from history
        -- auto_save_all_chats = true,         -- Auto-save all new chats

        -- Streaming
        -- enable_streaming = true,            -- Show responses as they generate
        -- stream_auto_scroll = true,          -- Auto-scroll during streaming
        -- large_stream_dialog = true,         -- Full-screen streaming dialog

        -- AI behavior
        -- selected_behavior = "standard",     -- "minimal", "standard", or "full"

        -- Reasoning (master toggle + per-provider sub-toggles)
        -- enable_reasoning = false,           -- Master toggle for reasoning/thinking
        -- anthropic_reasoning = false,        -- Anthropic extended thinking
        -- reasoning_budget = 32000,           -- Anthropic thinking budget tokens
        -- openai_reasoning = false,           -- OpenAI 5.1+ reasoning
        -- gemini_reasoning = false,           -- Gemini thinking
        -- deepseek_reasoning = true,          -- DeepSeek thinking (sub-toggle)

        -- Web search
        -- enable_web_search = false,          -- Global web search toggle

        -- Development
        -- debug = false,                      -- Console logging (false/minimal/names/full)
    },

    -- For custom AI behavior, use custom_actions.lua to define actions with:
    --   - behavior_override: Custom system prompt text
    --   - behavior_variant: "minimal", "full", or "none"
    -- See custom_actions.lua.sample for examples
}

return CONFIGURATION
